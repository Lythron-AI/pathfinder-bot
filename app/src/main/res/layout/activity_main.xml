<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res/auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pathfinder Bot"
                android:textColor="#F1F5F9"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/liveBotHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Espere..."
                android:textColor="#94A3B8"
                android:textSize="14sp" />

            <!-- Trajectory View Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="#1E293B"
                app:cardCornerRadius="16dp"
                app:strokeColor="#334155"
                app:strokeWidth="1dp">

                <com.pathfinder.gd.TrajectoryView
                    android:id="@+id/trajectoryView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Status Info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/summaryText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Listo para simular"
                    android:textColor="#38BDF8"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/detailsText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="v2.0 Native Core"
                    android:textColor="#64748B" />
            </LinearLayout>

            <!-- Physics Config Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="CONFIGURACIÓN FÍSICA"
                android:textColor="#94A3B8"
                android:textSize="12sp"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:boxStrokeColor="#38BDF8"
                app:hintTextColor="#38BDF8"
                android:hint="Modo de Juego">
                <AutoCompleteTextView
                    android:id="@+id/modeDropdown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:textColor="#F1F5F9" />
            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:hint="Velocidad">
                    <AutoCompleteTextView
                        android:id="@+id/speedDropdown"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:textColor="#F1F5F9" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Trigger">
                    <AutoCompleteTextView
                        android:id="@+id/triggerDropdown"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:textColor="#F1F5F9" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- Switches Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/miniSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mini"
                    android:textColor="#CBD5E1"
                    android:layout_marginEnd="16dp" />
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/gravitySwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Invertir"
                    android:textColor="#CBD5E1"
                    android:layout_marginEnd="16dp" />
            </LinearLayout>

            <!-- Bot Control Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="CONTROL DEL BOT"
                android:textColor="#94A3B8"
                android:textSize="12sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/pathfindButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="12dp"
                android:text="Pathfind (A* Nativo)"
                android:textSize="16sp"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/copyGdrButton"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Copiar .gdr2 al Portapapeles"
                android:textColor="#94A3B8" />


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/runBotButton"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Run Bot (Acc.)"
                    app:strokeColor="#38BDF8"
                    android:textColor="#38BDF8" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/ultraButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="MODO ULTRA"
                    android:backgroundTint="#EF4444"
                    android:textColor="#FFFFFF" />
            </LinearLayout>

            <!-- Advanced Section -->
             <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="Paquete del Juego">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/packageInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:singleLine="true"
                    android:textColor="#F1F5F9" />
            </com.google.android.material.textfield.TextInputLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/recalculateButton"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Refresh" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/loadScriptButton"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Load Script" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/openGameButton"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Open GD" />
                </LinearLayout>
            </HorizontalScrollView>

            <TextView
                android:id="@+id/detectionText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="#1E293B"
                android:padding="12dp"
                android:text="Pega lvlString para modo Ultra..."
                android:textColor="#64748B"
                android:textSize="12sp" />

            <!-- Hidden/Used indirectly -->
            <AutoCompleteTextView android:id="@+id/scenarioDropdown" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <AutoCompleteTextView android:id="@+id/scriptDropdown" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <com.google.android.material.textfield.TextInputEditText android:id="@+id/tapXInput" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <com.google.android.material.textfield.TextInputEditText android:id="@+id/tapYInput" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <TextView android:id="@+id/botPlanText" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <com.google.android.material.button.MaterialButton android:id="@+id/runScriptButton" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/dualSwitch" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/twoPlayerSwitch" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <com.google.android.material.slider.Slider android:id="@+id/inputSlider" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <TextView android:id="@+id/inputValue" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <com.google.android.material.button.MaterialButton android:id="@+id/openAccessibilityButton" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
